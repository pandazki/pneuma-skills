# Contextual Illustrator — shared image generation skill
#
# Pneuma populates `.env` automatically from the host mode's launch params
# (e.g. slide / illustrate / webcraft / kami collect these at first launch).
# This .env.example exists as reference; the live .env is gitignored.

# fal.ai — required for the default gpt-image-2 model and recommended overall
#   Get a key: https://fal.ai/dashboard/keys
FAL_KEY=

# OpenRouter — optional, fallback for gemini-3-pro only
#   Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
