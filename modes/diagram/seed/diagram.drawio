          <mxGeometry x="630" y="340" width="90" height="24" as="geometry"/>
        </mxCell>

        <!-- Hub to pillar connections (curved, varied styles) -->
        <mxCell id="e-p1" style="curved=1;strokeColor=#6c8ebf;strokeWidth=2;exitX=0.15;exitY=0.15;entryX=0.75;entryY=1;endArrow=blockThin;endFill=1;" edge="1" source="hub" target="p1" parent="1">
