<mxfile>
  <diagram id="arch" name="Architecture">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" math="0" shadow="0" adaptiveColors="auto">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Central hub -->
        <mxCell id="hub" value="&lt;font style=&quot;font-size:16px;&quot;&gt;&lt;b&gt;Pneuma&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#666&quot; style=&quot;font-size:10px;&quot;&gt;Co-Creation Runtime&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#f97316;strokeWidth=2;fontColor=#ffffff;shadow=1;gradientColor=#16213e;gradientDirection=south;" vertex="1" parent="1">
          <mxGeometry x="290" y="175" width="150" height="150" as="geometry"/>
        </mxCell>

        <!-- Four pillars as hexagons -->
        <mxCell id="p1" value="&lt;b&gt;Visual&lt;br&gt;Environment&lt;/b&gt;" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;gradientColor=#bbdefb;shadow=1;fontSize=11;perimeter=hexagonPerimeter2;size=0.2;" vertex="1" parent="1">
          <mxGeometry x="100" y="50" width="140" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;Skills&lt;br&gt;Engine&lt;/b&gt;" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;gradientColor=#b9e4b3;shadow=1;fontSize=11;perimeter=hexagonPerimeter2;size=0.2;" vertex="1" parent="1">
          <mxGeometry x="490" y="50" width="140" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;Continuous&lt;br&gt;Learning&lt;/b&gt;" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;gradientColor=#ffe082;shadow=1;fontSize=11;perimeter=hexagonPerimeter2;size=0.2;" vertex="1" parent="1">
          <mxGeometry x="100" y="370" width="140" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="&lt;b&gt;Distribution&lt;br&gt;&amp;amp; Sharing&lt;/b&gt;" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;gradientColor=#d1c4e9;shadow=1;fontSize=11;perimeter=hexagonPerimeter2;size=0.2;" vertex="1" parent="1">
          <mxGeometry x="490" y="370" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- Pillar details (small rounded rects) -->
        <mxCell id="d1a" value="Live Preview" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=none;fontSize=9;fontColor=#1565c0;" vertex="1" parent="1">
          <mxGeometry x="20" y="140" width="80" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="d1b" value="Pan/Zoom" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=none;fontSize=9;fontColor=#1565c0;" vertex="1" parent="1">
          <mxGeometry x="20" y="170" width="80" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="d1c" value="Select/Annotate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=none;fontSize=9;fontColor=#1565c0;" vertex="1" parent="1">
          <mxGeometry x="20" y="200" width="80" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="d2a" value="Seed Templates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=none;fontSize=9;fontColor=#2e7d32;" vertex="1" parent="1">
          <mxGeometry x="630" y="140" width="90" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="d2b" value="SKILL.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=none;fontSize=9;fontColor=#2e7d32;" vertex="1" parent="1">
          <mxGeometry x="630" y="170" width="90" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="d2c" value="References" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=none;fontSize=9;fontColor=#2e7d32;" vertex="1" parent="1">
          <mxGeometry x="630" y="200" width="90" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="d3a" value="Evolution Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=none;fontSize=9;fontColor=#f57f17;" vertex="1" parent="1">
          <mxGeometry x="20" y="310" width="90" height="24" as="geometry"/>
