        <mxCell id="e-p4" style="curved=1;strokeColor=#9673a6;strokeWidth=2;exitX=0.85;exitY=0.85;entryX=0.25;entryY=0;endArrow=blockThin;endFill=1;" edge="1" source="hub" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
