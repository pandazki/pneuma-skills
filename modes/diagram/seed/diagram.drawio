        <mxCell id="e-d2" style="curved=1;strokeColor=#a5d6a7;strokeWidth=1;dashed=1;dashPattern=4 4;entryX=0;entryY=0.5;exitX=1;exitY=0.5;endArrow=none;" edge="1" source="p2" target="d2b" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-d3" style="curved=1;strokeColor=#ffe082;strokeWidth=1;dashed=1;dashPattern=4 4;entryX=1;entryY=0.5;exitX=0;exitY=0.5;endArrow=none;" edge="1" source="p3" target="d3a" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-d4" style="curved=1;strokeColor=#ce93d8;strokeWidth=1;dashed=1;dashPattern=4 4;entryX=0;entryY=0.5;exitX=1;exitY=0.5;endArrow=none;" edge="1" source="p4" target="d4a" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Backend indicators at bottom -->
        <mxCell id="be-label" value="Agent Backends" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="290" y="430" width="150" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="be1" value="Claude Code" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="452" width="100" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="be2" value="Codex" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="375" y="452" width="100" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="e-be" style="edgeStyle=orthogonalEdgeStyle;curved=1;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=6 3;endArrow=none;exitX=0.5;exitY=1;" edge="1" source="hub" target="be-label" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="lifecycle" name="Lifecycle">
