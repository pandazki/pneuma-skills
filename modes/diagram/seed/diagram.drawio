        <!-- Detail connections (thin, dashed) -->
        <mxCell id="e-d1" style="curved=1;strokeColor=#90caf9;strokeWidth=1;dashed=1;dashPattern=4 4;entryX=1;entryY=0.5;exitX=0;exitY=0.5;endArrow=none;" edge="1" source="p1" target="d1b" parent="1">
          <mxGeometry relative="1" as="geometry"/>
